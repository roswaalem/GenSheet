        "title": "Gensheet",
        "width": 1180,
        "height": 760,
        "minWidth": 940,
        "minHeight": 620
      }
    ],
    "security": { "csp": null }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/OWNER/REPO/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0QjE1QTAwRTlDNzRGRDkKUldUWlQ4ZnBBRnF4WkNhaFU1MUVNUGFXMDVGQzJvSmF5RmVGNUZpUnFzbXA0TXBKRXBVOVgrbEsK",
      "windows": { "installMode": "passive" }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
