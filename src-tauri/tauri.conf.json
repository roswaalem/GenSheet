{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gensheet",
  "version": "0.1.0",
  "identifier": "com.rstudios.gensheet",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
